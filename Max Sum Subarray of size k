class Solution {
    public int maxSubarraySum(int[] arr, int k) {
       
       int max=Integer.MIN_VALUE;
       int sum=0;
       int i=0;int j=0;
       while(j<arr.length){
          
          
           if(j-i+1<k){
               j++;
           }
           else if(j-i+1==k){
                sum=sum+arr[j] ;
                 j++;
               max=Math.max(max,sum);
              
               
           }
       }
       return max;
        
    }
}
